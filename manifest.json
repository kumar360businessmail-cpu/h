{
  "manifest_version": 3,
  "name": "Simplify Copilot - Job Application Assistant",
  "version": "1.0.0",
  "description": "Privacy-first offline extension for autofilling job applications, tracking applications & generating AI resumes locally",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Simplify Copilot"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
