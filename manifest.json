{
  "manifest_version": 3,
  "name": "Simplify Copilot - Job Application Assistant",
  "version": "1.0.0",
  "description": "Privacy-first offline extension for autofilling job applications, tracking applications & generating AI resumes locally",
  "permissions": [
    "storage",
    "scripting",
    "webRequest",
    "tabs",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Simplify Copilot",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
